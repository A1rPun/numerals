{
  "name": "numerals",
  "version": "0.0.1",
  "description": "Numerals of the world",
  "main": "main.js",
  "files": [
    "dist/numerals.js"
  ],
  "scripts": {
    "build": "rollup main.js --format umd --name \"Numerals\" --file dist/numerals.js",
    "build-prod": "npm run build -- --environment INCLUDE_DEPS,BUILD:production",
    "test": "jest"
  },
  "jest": {
    "transform": {
      "^.+\\.jsx?$": "babel-jest"
    }
  },
  "keywords": [
    "numerals",
    "numeral",
    "system",
    "western",
    "eastern",
    "arabic",
    "indian",
    "roman",
    "egyptian",
    "babylonian",
    "maya"
  ],
  "author": "A1rPun",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.4.5",
    "@babel/preset-env": "^7.4.5",
    "babel-jest": "^24.8.0",
    "jest": "^24.8.0",
    "rollup": "^1.14.0",
    "rollup-plugin-babel": "^4.3.2"
  }
}
